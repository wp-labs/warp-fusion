use "network.wfs"

// 端口扫描检测 —— 静态窗口白名单
//
// 架构：
//   1. scanner_whitelist 窗口（over=0，静态）从 whitelist stream 加载白名单
//   2. conn_events 窗口接收 netflow 事件
//   3. anti join 排除白名单 IP
//
// 注：ANTI join 需要完整引擎运行时验证（WFL test runner 不支持跨窗口 join）。
//     解析和编译已支持，运行时通过 execute_joins 返回 false 来排除匹配事件。

rule port_scan_whitelist {
    events { c : conn_events && action == "syn" }
    match<sip:5m> {
        on event { c.dport | distinct | count >= 10; }
    } -> score(80.0)
    join scanner_whitelist anti on c.sip == scanner_whitelist.sip
    entity(ip, c.sip)
    yield security_alerts (sip = c.sip, alert_type = "port_scan", detail = "distinct ports >= 10")
}

test scan_detected for port_scan_whitelist {
  input {
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "80", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:00Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "443", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:01Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "8080", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:02Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "22", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:03Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "3306", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:04Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "5432", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:05Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "6379", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:06Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "27017", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:07Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "9200", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:08Z");
    row(c, sip = "10.0.0.99", dip = "192.168.1.1", dport = "11211", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:09Z");
  }
  expect {
    hits == 1;
    hit[0].score == 80.0;
    hit[0].entity_id == "10.0.0.99";
  }
}

test below_threshold for port_scan_whitelist {
  input {
    row(c, sip = "10.0.0.1", dip = "192.168.1.1", dport = "80", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:00Z");
    row(c, sip = "10.0.0.1", dip = "192.168.1.1", dport = "80", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:01Z");
    row(c, sip = "10.0.0.1", dip = "192.168.1.1", dport = "443", bytes = "100", protocol = "tcp", action = "syn", event_time = "2026-01-01T00:00:02Z");
  }
  expect {
    hits == 0;
  }
}
